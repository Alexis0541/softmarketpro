---
import '~/assets/styles/tailwind.css';
import Header from '~/components/dc/Header.astro';
import Footer from '~/components/dc/Footer.astro';
import { site, type Lang } from '~/data/digiclara';
import { withBase } from '~/utils/paths';

interface Props {
  lang: Lang;
  title?: string;
  description?: string;
  image?: string;
  type?: string;
  noindex?: boolean;
}
const { lang, title = site.name, description = site.descriptions[lang], image = '/assets/digiclara-og.svg', type = 'website', noindex = false } = Astro.props;
const pageTitle = title === site.name ? site.name : `${title} | ${site.name}`;
const canonical = new URL(Astro.url.pathname, Astro.site || 'https://digiclara.example').toString();
---

<!doctype html>
<html lang={lang === 'es' ? 'es-ES' : 'en'} data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex,follow" />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="es" href={withBase('/es/')} />
    <link rel="alternate" hreflang="en" href={withBase('/en/')} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:image" content={withBase(image)} />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href={withBase('/assets/favicon.svg')} type="image/svg+xml" />
    <link rel="apple-touch-icon" href={withBase('/assets/apple-touch-icon.svg')} />
    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'WebSite',
      name: site.name,
      description,
      url: canonical,
      inLanguage: lang === 'es' ? 'es-ES' : 'en',
    })} />
  </head>
  <body>
    <Header lang={lang} />
    <main id="contenido">
      <slot />
    </main>
    <Footer lang={lang} />
    <button class="back-top" type="button" data-back-top aria-label={lang === 'es' ? 'Volver arriba' : 'Back to top'}>Top</button>
    <script>
      document.querySelector('[data-back-top]')?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
    </script>
  </body>
</html>
