---
import { Icon } from 'astro-icon/components';
import Headline from '~/components/ui/Headline.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import { formatPrice, type Product } from '~/data/software';
import type { Lang } from '~/utils/i18n';
import { localizePath, ui } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

interface Props {
  title?: string;
  subtitle?: string;
  tagline?: string;
  products: readonly Product[];
  id?: string;
  limit?: number;
  lang?: Lang;
}

const { title = '', subtitle = '', tagline = '', products = [], id, limit, lang = 'es' } = Astro.props;
const visibleProducts = limit ? products.slice(0, limit) : products;
const t = ui[lang];
---

<WidgetWrapper id={id} containerClass="max-w-7xl mx-auto">
  <Headline title={title} subtitle={subtitle} tagline={tagline} />

  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
    {
      visibleProducts.map((product) => (
        <article class="flex h-full flex-col overflow-hidden rounded-md border border-gray-200 bg-white shadow-sm transition hover:-translate-y-0.5 hover:shadow-md dark:border-slate-700 dark:bg-slate-900">
          <button
            type="button"
            class="relative bg-slate-100 text-left dark:bg-slate-800"
            data-open-product
            data-product={JSON.stringify(product)}
          >
            <span class="absolute left-3 top-3 rounded bg-red-600 px-2.5 py-1 text-xs font-bold text-white">
              {product.badge}
            </span>
            <img src={product.image} alt={product.name} loading="lazy" class="h-52 w-full object-contain p-5" />
          </button>

          <div class="flex flex-1 flex-col p-5">
            <button type="button" class="text-left" data-open-product data-product={JSON.stringify(product)}>
              <h3 class="text-lg font-bold leading-snug hover:text-primary dark:text-white">{product.name}</h3>
            </button>
            <p class="mt-2 line-clamp-3 text-sm text-muted">{product.description}</p>

            <div class="mt-4 flex items-end gap-2">
              <span class="text-2xl font-extrabold text-slate-950 dark:text-white">{formatPrice(product.price, lang)}</span>
              <span class="text-sm text-muted line-through">{formatPrice(product.oldPrice, lang)}</span>
            </div>
            <p class="mt-1 text-xs font-semibold text-green-700 dark:text-green-300">{t.vatIncluded}</p>

            <ul class="mt-4 grid gap-1.5 text-sm text-slate-700 dark:text-slate-300">
              {product.features.slice(0, 3).map((feature) => (
                <li class="flex items-center gap-2">
                  <Icon name="tabler:check" class="h-4 w-4 text-primary" />
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <div class="mt-auto grid gap-2 pt-5">
              <button
                type="button"
                class="inline-flex w-full items-center justify-center gap-2 rounded-md bg-primary px-4 py-3 text-sm font-semibold text-white transition hover:bg-primary/90"
                data-add-to-cart
                data-product={JSON.stringify({
                  slug: product.slug,
                  name: product.name,
                  price: product.price,
                  image: product.image,
                })}
              >
                <Icon name="tabler:shopping-cart-plus" class="h-5 w-5" />
                <span>{t.addToCart}</span>
              </button>
              <button
                type="button"
                class="inline-flex w-full items-center justify-center gap-2 rounded-md border border-slate-300 px-4 py-3 text-sm font-semibold transition hover:border-primary hover:text-primary dark:border-slate-700"
                data-open-product
                data-product={JSON.stringify(product)}
              >
                {t.viewDetails}
              </button>
            </div>
          </div>
        </article>
      ))
    }
  </div>
</WidgetWrapper>

<div class="fixed inset-0 z-[90] hidden bg-slate-950/60 p-4" data-product-modal-overlay>
  <div class="mx-auto mt-6 max-h-[calc(100vh-3rem)] max-w-4xl overflow-y-auto rounded-md bg-white shadow-2xl dark:bg-slate-950" data-product-modal>
    <div class="flex items-center justify-between border-b border-slate-200 p-5 dark:border-slate-800">
      <div>
        <p class="text-sm font-bold uppercase tracking-wide text-primary">{t.productDetail}</p>
        <h2 class="text-2xl font-black dark:text-white" data-modal-name>{t.product}</h2>
      </div>
      <button class="rounded-md p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800" type="button" data-product-close>
        <Icon name="tabler:x" class="h-6 w-6" />
      </button>
    </div>

    <div class="grid gap-8 p-6 md:grid-cols-[0.9fr_1.1fr]">
      <div class="rounded-md bg-slate-100 p-6 dark:bg-slate-900">
        <img data-modal-image src="" alt="" class="mx-auto h-80 w-full object-contain" />
      </div>
      <div>
        <div class="mb-3 flex items-end gap-3">
          <span class="text-4xl font-black text-slate-950 dark:text-white" data-modal-price>0,00 €</span>
          <span class="text-lg text-muted line-through" data-modal-old-price></span>
        </div>
        <p class="font-semibold text-green-700 dark:text-green-300">{t.modalVat}</p>
        <p class="mt-5 text-slate-600 dark:text-slate-300" data-modal-description></p>
        <ul class="mt-5 grid gap-2 text-sm text-slate-700 dark:text-slate-300" data-modal-features></ul>

        <label class="mt-6 block text-sm font-bold text-slate-700 dark:text-slate-200" for="modal-quantity">
          {t.quantity}
        </label>
        <div class="mt-2 flex max-w-[180px] items-center rounded-md border border-slate-300 dark:border-slate-700">
          <button type="button" class="px-4 py-3 font-black" data-modal-qty-dec>-</button>
          <input id="modal-quantity" class="w-full bg-transparent text-center font-black outline-none" type="number" min="1" value="1" data-modal-quantity />
          <button type="button" class="px-4 py-3 font-black" data-modal-qty-inc>+</button>
        </div>

        <div class="mt-6 grid gap-3 sm:grid-cols-2">
          <button type="button" class="rounded-md bg-primary px-5 py-4 font-black text-white hover:bg-primary/90" data-modal-add>
            {t.addToCart}
          </button>
          <button type="button" class="rounded-md bg-green-600 px-5 py-4 font-black text-white hover:bg-green-700" data-modal-buy>
            {t.buyNow}
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script define:vars={{ checkoutPath: getPermalink(localizePath('/checkout', lang)), locale: t.locale, addToCartText: t.addToCart, addedToCartText: t.addedToCart }}>
  // @ts-nocheck
  const cartKey = 'softmarket-cart';
  const euro = new Intl.NumberFormat(locale, { style: 'currency', currency: 'EUR' });
  let activeProduct = null;

  const readCart = () => {
    try {
      return JSON.parse(localStorage.getItem(cartKey) || '[]');
    } catch {
      return [];
    }
  };

  const writeCart = (cart) => {
    localStorage.setItem(cartKey, JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart:updated'));
  };

  const addProductToCart = (product, quantity = 1) => {
    const cart = readCart();
    const existing = cart.find((item) => item.slug === product.slug);

    if (existing) {
      existing.quantity += quantity;
    } else {
      cart.push({
        slug: product.slug,
        name: product.name,
        price: product.price,
        image: product.image,
        quantity,
      });
    }

    writeCart(cart);
  };

  const overlay = document.querySelector('[data-product-modal-overlay]');
  const modalQuantity = document.querySelector('[data-modal-quantity]');

  const closeProductModal = () => {
    overlay?.classList.add('hidden');
  };

  const openProductModal = (product) => {
    activeProduct = product;
    const features = product.features || [];
    document.querySelector('[data-modal-name]').textContent = product.name;
    document.querySelector('[data-modal-image]').setAttribute('src', product.image);
    document.querySelector('[data-modal-image]').setAttribute('alt', product.name);
    document.querySelector('[data-modal-price]').textContent = euro.format(product.price);
    document.querySelector('[data-modal-old-price]').textContent = euro.format(product.oldPrice);
    document.querySelector('[data-modal-description]').textContent = product.description;
    document.querySelector('[data-modal-features]').innerHTML = features
      .map((feature) => `<li class="flex items-center gap-2"><span class="text-primary">✓</span><span>${feature}</span></li>`)
      .join('');
    modalQuantity.value = '1';
    overlay?.classList.remove('hidden');
  };

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    const openButton = target.closest('[data-open-product]');
    if (openButton) {
      openProductModal(JSON.parse(openButton.getAttribute('data-product') || '{}'));
      return;
    }

    const addButton = target.closest('[data-add-to-cart]');
    if (addButton) {
      const product = JSON.parse(addButton.getAttribute('data-product') || '{}');
      addProductToCart(product, 1);
      addButton.textContent = addedToCartText;
      setTimeout(() => {
        addButton.textContent = addToCartText;
      }, 1200);
      return;
    }

    if (target.closest('[data-product-close]') || target === overlay) closeProductModal();
    if (target.closest('[data-modal-qty-dec]')) modalQuantity.value = String(Math.max(1, Number(modalQuantity.value || 1) - 1));
    if (target.closest('[data-modal-qty-inc]')) modalQuantity.value = String(Number(modalQuantity.value || 1) + 1);

    if (target.closest('[data-modal-add]') && activeProduct) {
      addProductToCart(activeProduct, Math.max(1, Number(modalQuantity.value || 1)));
      closeProductModal();
    }

    if (target.closest('[data-modal-buy]') && activeProduct) {
      addProductToCart(activeProduct, Math.max(1, Number(modalQuantity.value || 1)));
      window.location.href = checkoutPath;
    }
  });
</script>
