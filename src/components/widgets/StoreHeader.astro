---
import { Icon } from 'astro-icon/components';
import Logo from '~/components/Logo.astro';
import { getCategories } from '~/data/software';
import type { Lang } from '~/utils/i18n';
import { alternateLangPath, localizePath, ui } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

interface Props {
  lang?: Lang;
}

const { lang = 'es' } = Astro.props;
const t = ui[lang];
const categories = getCategories(lang);
const esHref = getPermalink(alternateLangPath(Astro.url.pathname, 'es'));
const enHref = getPermalink(alternateLangPath(Astro.url.pathname, 'en'));
---

<header class="sticky top-0 z-50 border-b border-slate-200 bg-white shadow-sm dark:border-slate-800 dark:bg-slate-950">
  <div class="bg-slate-950 px-4 py-2 text-center text-sm font-semibold text-white">
    {t.topBar}
  </div>

  <div class="mx-auto flex max-w-7xl flex-col gap-4 px-4 py-4 sm:px-6 lg:flex-row lg:items-center lg:justify-between">
    <a class="flex items-center" href={getPermalink(localizePath('/', lang))}>
      <Logo />
    </a>

    <form class="relative flex-1 lg:max-w-xl" action={getPermalink(localizePath('/software', lang))}>
      <Icon name="tabler:search" class="pointer-events-none absolute left-3 top-1/2 h-5 w-5 -translate-y-1/2 text-slate-400" />
      <input
        class="w-full rounded-md border border-slate-300 bg-white py-3 pl-10 pr-4 text-sm outline-none transition focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900"
        type="search"
        name="q"
        placeholder={t.searchPlaceholder}
      />
    </form>

    <div class="flex flex-wrap items-center gap-3">
      <a class="hidden text-sm font-semibold text-slate-700 hover:text-primary dark:text-slate-200 sm:inline" href={getPermalink(localizePath('/cuenta', lang))}>
        {t.account}
      </a>
      <a class="hidden text-sm font-semibold text-slate-700 hover:text-primary dark:text-slate-200 sm:inline" href={getPermalink(localizePath('/contact', lang))}>
        {t.help}
      </a>
      <div class="inline-flex rounded-md border border-slate-300 p-1 text-xs font-black dark:border-slate-700" aria-label={t.langLabel}>
        <a class:list={['rounded px-2 py-1', lang === 'es' ? 'bg-primary text-white' : 'text-slate-700 dark:text-slate-200']} href={esHref}>{t.es}</a>
        <a class:list={['rounded px-2 py-1', lang === 'en' ? 'bg-primary text-white' : 'text-slate-700 dark:text-slate-200']} href={enHref}>{t.en}</a>
      </div>
      <button
        type="button"
        class="inline-flex items-center gap-2 rounded-md bg-primary px-4 py-3 text-sm font-bold text-white shadow-sm transition hover:bg-primary/90"
        data-cart-open
      >
        <Icon name="tabler:shopping-cart" class="h-5 w-5" />
        <span data-cart-total>0,00 €</span>
        <span class="rounded bg-white/20 px-2 py-0.5" data-cart-count>0</span>
      </button>
    </div>
  </div>

  <nav class="border-t border-slate-100 bg-slate-50 dark:border-slate-800 dark:bg-slate-900">
    <div class="mx-auto flex max-w-7xl gap-1 overflow-x-auto px-4 py-2 sm:px-6">
      <a class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-800" href={getPermalink(localizePath('/', lang))}>
        {t.navHome}
      </a>
      <a class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-800" href={getPermalink(localizePath('/software', lang))}>
        {t.navStore}
      </a>
      {categories.map((category) => (
        <a
          class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-800"
          href={getPermalink(localizePath(`/software/${category.slug}`, lang))}
        >
          {category.name}
        </a>
      ))}
      <a class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-800" href={getPermalink(localizePath('/contact', lang))}>
        {t.navContact}
      </a>
      <a class="shrink-0 rounded px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-white hover:text-primary dark:text-slate-200 dark:hover:bg-slate-800" href={getPermalink(localizePath('/cuenta', lang))}>
        {t.navAccount}
      </a>
    </div>
  </nav>
</header>

<div class="fixed inset-0 z-[70] hidden bg-slate-950/50" data-cart-overlay></div>
<aside
  class="fixed right-0 top-0 z-[80] flex h-full w-full max-w-md translate-x-full flex-col bg-white shadow-2xl transition-transform duration-300 dark:bg-slate-950"
  data-cart-panel
  aria-label={t.cartLabel}
>
  <div class="flex items-center justify-between border-b border-slate-200 p-5 dark:border-slate-800">
    <div>
      <p class="text-sm font-bold uppercase tracking-wide text-primary">{t.order}</p>
      <h2 class="text-2xl font-black dark:text-white">{t.cartLabel}</h2>
    </div>
    <button class="rounded-md p-2 text-slate-500 hover:bg-slate-100 dark:hover:bg-slate-800" type="button" data-cart-close>
      <Icon name="tabler:x" class="h-6 w-6" />
    </button>
  </div>

  <div class="flex-1 overflow-y-auto p-5" data-cart-items>
    <p class="rounded-md bg-slate-100 p-4 text-sm text-slate-600 dark:bg-slate-900 dark:text-slate-300">
      {t.emptyCart}
    </p>
  </div>

  <div class="border-t border-slate-200 p-5 dark:border-slate-800">
    <div class="mb-4 flex items-center justify-between text-lg font-black dark:text-white">
      <span>{t.total}</span>
      <span data-cart-drawer-total>0,00 €</span>
    </div>
    <button
      type="button"
      class="w-full rounded-md bg-green-600 px-5 py-4 text-center text-base font-black text-white transition hover:bg-green-700"
      data-checkout
    >
      {t.buyNow}
    </button>
    <p class="mt-3 text-center text-xs text-slate-500">
      {t.cartDemo}
    </p>
  </div>
</aside>

<script define:vars={{ checkoutPath: getPermalink(localizePath('/checkout', lang)), locale: t.locale, emptyCart: t.emptyCart, removeText: t.delete, emptyAlert: t.cartEmptyAlert }}>
  // @ts-nocheck
  const cartKey = 'softmarket-cart';
  const euro = new Intl.NumberFormat(locale, { style: 'currency', currency: 'EUR' });

  const readCart = () => {
    try {
      return JSON.parse(localStorage.getItem(cartKey) || '[]');
    } catch {
      return [];
    }
  };

  const saveCart = (cart) => {
    localStorage.setItem(cartKey, JSON.stringify(cart));
    window.dispatchEvent(new CustomEvent('cart:updated'));
  };

  const cartPanel = document.querySelector('[data-cart-panel]');
  const cartOverlay = document.querySelector('[data-cart-overlay]');
  const itemsNode = document.querySelector('[data-cart-items]');

  const openCart = () => {
    cartPanel?.classList.remove('translate-x-full');
    cartOverlay?.classList.remove('hidden');
  };

  const closeCart = () => {
    cartPanel?.classList.add('translate-x-full');
    cartOverlay?.classList.add('hidden');
  };

  const renderCart = () => {
    const cart = readCart();
    const count = cart.reduce((sum, item) => sum + item.quantity, 0);
    const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);

    document.querySelectorAll('[data-cart-count]').forEach((node) => {
      node.textContent = String(count);
    });
    document.querySelectorAll('[data-cart-total], [data-cart-drawer-total]').forEach((node) => {
      node.textContent = euro.format(total);
    });

    if (!itemsNode) return;

    if (cart.length === 0) {
      itemsNode.innerHTML =
        `<p class="rounded-md bg-slate-100 p-4 text-sm text-slate-600 dark:bg-slate-900 dark:text-slate-300">${emptyCart}</p>`;
      return;
    }

    itemsNode.innerHTML = cart
      .map(
        (item) => `
          <div class="mb-4 flex gap-3 rounded-md border border-slate-200 p-3 dark:border-slate-800">
            <img src="${item.image}" alt="${item.name}" class="h-16 w-16 rounded bg-slate-100 object-contain p-1" />
            <div class="min-w-0 flex-1">
              <h3 class="text-sm font-bold dark:text-white">${item.name}</h3>
              <p class="text-sm font-semibold text-primary">${euro.format(item.price)}</p>
              <div class="mt-2 flex items-center gap-2">
                <button class="rounded border px-2 py-1 text-sm" data-cart-dec="${item.slug}">-</button>
                <span class="w-6 text-center text-sm font-bold">${item.quantity}</span>
                <button class="rounded border px-2 py-1 text-sm" data-cart-inc="${item.slug}">+</button>
                <button class="ml-auto text-xs font-bold text-red-600" data-cart-remove="${item.slug}">${removeText}</button>
              </div>
            </div>
          </div>
        `
      )
      .join('');
  };

  document.addEventListener('click', (event) => {
    const target = event.target;
    if (!(target instanceof Element)) return;

    if (target.closest('[data-cart-open]')) openCart();
    if (target.closest('[data-cart-close]') || target === cartOverlay) closeCart();

    const inc = target.closest('[data-cart-inc]')?.getAttribute('data-cart-inc');
    const dec = target.closest('[data-cart-dec]')?.getAttribute('data-cart-dec');
    const remove = target.closest('[data-cart-remove]')?.getAttribute('data-cart-remove');

    if (inc || dec || remove) {
      let cart = readCart();
      cart = cart
        .map((item) => {
          if (item.slug !== (inc || dec || remove)) return item;
          if (inc) return { ...item, quantity: item.quantity + 1 };
          if (dec) return { ...item, quantity: item.quantity - 1 };
          return { ...item, quantity: 0 };
        })
        .filter((item) => item.quantity > 0);
      saveCart(cart);
    }

    if (target.closest('[data-checkout]')) {
      const cart = readCart();
      if (cart.length === 0) {
        alert(emptyAlert);
        return;
      }
      window.location.href = checkoutPath;
    }
  });

  window.addEventListener('cart:updated', renderCart);
  renderCart();
</script>
