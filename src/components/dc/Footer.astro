---
import Logo from './Logo.astro';
import { legalPages, navItems, site, type Lang } from '~/data/digiclara';
import { withBase } from '~/utils/paths';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const legal = Object.values(legalPages).map((page) => ({ slug: page[lang][0], title: page[lang][1] }));
---

<footer class="site-footer">
  <div class="footer-grid">
    <div>
      <Logo />
      <p>{site.descriptions[lang]}</p>
    </div>
    <div>
      <h2>{lang === 'es' ? 'Secciones' : 'Sections'}</h2>
      <ul>{navItems(lang).slice(1, 7).map((item) => <li><a href={withBase(item.href)}>{item.label}</a></li>)}</ul>
    </div>
    <div>
      <h2>{lang === 'es' ? 'Legal' : 'Legal'}</h2>
      <ul>{legal.map((item) => <li><a href={withBase(`/${lang}/legal/${item.slug}/`)}>{item.title}</a></li>)}</ul>
    </div>
    <div>
      <h2>{lang === 'es' ? 'Contacto' : 'Contact'}</h2>
      <p>{lang === 'es' ? 'El correo editorial se debe completar antes de activar formularios.' : 'The editorial email must be completed before enabling forms.'}</p>
      <a href={withBase(`/${lang}/${lang === 'es' ? 'contacto' : 'contact'}/`)}>{lang === 'es' ? 'Pagina de contacto' : 'Contact page'}</a>
    </div>
  </div>
  <p class="fineprint">DigiClara. {lang === 'es' ? 'Contenido educativo independiente.' : 'Independent educational content.'}</p>
</footer>
