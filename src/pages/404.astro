---
import Layout from '~/layouts/Layout.astro';
import { getLangFromUrl, localizePath } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

const title = `Error 404`;
const lang = getLangFromUrl(Astro.url);
const copy = lang === 'en'
  ? {
      message: "Sorry, we couldn't find this page.",
      text: 'Do not worry, you can continue browsing the software store from the homepage.',
      button: 'Back to homepage',
    }
  : {
      message: 'Lo sentimos, no encontramos esta pagina.',
      text: 'No te preocupes, puedes seguir navegando por la tienda de software desde el inicio.',
      button: 'Volver al inicio',
    };
---

<Layout metadata={{ title }} lang={lang}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">Error</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">{copy.message}</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">{copy.text}</p>
        <a rel="noopener noreferrer" href={getPermalink(localizePath('/', lang))} class="btn ml-4">{copy.button}</a>
      </div>
    </div>
  </section>
</Layout>
