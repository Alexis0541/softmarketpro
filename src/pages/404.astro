---
import DigiLayout from '~/layouts/DigiLayout.astro';
import { withBase } from '~/utils/paths';
---
<DigiLayout lang="es" title="Pagina no encontrada" description="La pagina solicitada no existe en DigiClara." noindex={true}>
  <section class="section"><div class="page-shell article-body">
    <p class="eyebrow">404</p>
    <h1>Pagina no encontrada</h1>
    <p>Puede que el contenido haya cambiado de ruta durante la transformacion editorial de DigiClara.</p>
    <div class="button-row"><a class="button primary" href={withBase('/es/')}>Ir al inicio</a><a class="button" href={withBase('/en/')}>English home</a></div>
  </div></section>
</DigiLayout>
