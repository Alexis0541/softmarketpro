---
import DigiLayout from '~/layouts/DigiLayout.astro';
import { site } from '~/data/digiclara';
---
<DigiLayout lang="es" title="Contacto" description="Contacto editorial de DigiClara.">
  <section class="section"><div class="page-shell article-body">
    <p class="eyebrow">Contacto</p>
    <h1>Contacto editorial</h1>
    <p>DigiClara es responsabilidad editorial de {site.ownerName}. El sitio se gestiona desde {site.country} y atiende consultas sobre correcciones, sugerencias, problemas tecnicos y propuestas editoriales por correo electronico.</p>
    <div class="notice sage">
      <h2>Datos de contacto</h2>
      <p><strong>Responsable:</strong> {site.ownerName}</p>
      <p><strong>Rol:</strong> Responsable editorial de DigiClara</p>
      <p><strong>Pais:</strong> {site.country}</p>
      <p><strong>Correo:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>
    <a class="button primary" href={`mailto:${site.email}?subject=Consulta%20desde%20DigiClara`}>Enviar un correo</a>
  </div></section>
</DigiLayout>
