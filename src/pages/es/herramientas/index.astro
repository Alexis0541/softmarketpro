---
import DigiLayout from '~/layouts/DigiLayout.astro';
import { ui } from '~/data/digiclara';
const lang = 'es';
const t = ui[lang];
---

<DigiLayout lang={lang} title="Herramientas locales" description="Herramientas locales de seguridad y productividad digital.">
  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">Herramientas</p><h1>Utilidades que funcionan en tu navegador</h1><p>No enviamos contraseñas, frases ni textos a servidores. Las estimaciones son educativas y no sustituyen una auditoría.</p></header>
    <div class="grid grid-3">
      <div class="tool-card"><h2>Generador de contraseñas</h2><button class="button primary" data-generate>Generar</button><input data-password readonly aria-label="Contraseña generada" /><button class="button" data-copy-password>Copiar</button></div>
      <div class="tool-card"><h2>Generador de frases</h2><button class="button primary" data-passphrase>Crear frase</button><input data-passphrase-output readonly aria-label="Frase de contraseña generada" /><button class="button" data-copy-passphrase>Copiar</button></div>
      <div class="tool-card"><h2>Fortaleza educativa</h2><input data-strength type="text" placeholder="Escribe una contraseña de prueba" /><p data-strength-result>{t.estimate}</p></div>
      <div class="tool-card"><h2>Lectura estimada</h2><textarea data-read-text rows="5" placeholder="Pega un texto"></textarea><p data-read-result>{t.estimate}</p></div>
      <div class="tool-card"><h2>Lista para proteger Windows</h2><ul><li><label><input type="checkbox" /> Actualizaciones activas</label></li><li><label><input type="checkbox" /> Copia de seguridad probada</label></li><li><label><input type="checkbox" /> Bloqueo de pantalla</label></li><li><label><input type="checkbox" /> Defender sin alertas críticas</label></li></ul></div>
      <div class="tool-card"><h2>Lista anti-phishing</h2><ul><li><label><input type="checkbox" /> Revisar remitente</label></li><li><label><input type="checkbox" /> Comprobar dominio</label></li><li><label><input type="checkbox" /> Evitar adjuntos inesperados</label></li><li><label><input type="checkbox" /> Confirmar solicitudes urgentes por otro canal</label></li></ul></div>
      <div class="tool-card"><h2>Revisor de enlaces y QR</h2><input data-url-check type="url" placeholder="Pega la URL que muestra el QR" /><p data-url-result>{t.estimate}</p></div>
      <div class="tool-card"><h2>Auditor de enlaces en la nube</h2><ul data-cloud-audit><li><label><input type="checkbox" /> Cualquiera con el enlace puede acceder</label></li><li><label><input type="checkbox" /> Tiene permiso de edición</label></li><li><label><input type="checkbox" /> Hay usuarios externos</label></li><li><label><input type="checkbox" /> El enlace tiene más de 30 días</label></li></ul><p data-cloud-result>{t.estimate}</p></div>
      <div class="tool-card"><h2>Permisos de extensiones</h2><ul data-extension-audit><li><label><input type="checkbox" /> Leer y cambiar datos en todos los sitios</label></li><li><label><input type="checkbox" /> Acceso al historial</label></li><li><label><input type="checkbox" /> Acceso a descargas</label></li><li><label><input type="checkbox" /> Acceso al portapapeles</label></li></ul><p data-extension-result>{t.estimate}</p></div>
    </div>
  </div></section>
  <script>
    const chars = 'ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz23456789!#%+?';
    const words = ['claro', 'luna', 'mapa', 'tecla', 'senda', 'rio', 'nube', 'foco', 'calma', 'piedra', 'bosque', 'farol'];
    const pick = (list) => list[Math.floor(Math.random() * list.length)];
    document.querySelector('[data-generate]')?.addEventListener('click', () => {
      document.querySelector('[data-password]').value = Array.from({ length: 20 }, () => pick(chars)).join('');
    });
    document.querySelector('[data-passphrase]')?.addEventListener('click', () => {
      document.querySelector('[data-passphrase-output]').value = Array.from({ length: 5 }, () => pick(words)).join('-') + '-' + Math.floor(10 + Math.random() * 90);
    });
    document.querySelector('[data-copy-password]')?.addEventListener('click', async () => {
      const value = document.querySelector('[data-password]').value;
      if (value) await navigator.clipboard.writeText(value);
    });
    document.querySelector('[data-copy-passphrase]')?.addEventListener('click', async () => {
      const value = document.querySelector('[data-passphrase-output]').value;
      if (value) await navigator.clipboard.writeText(value);
    });
    document.querySelector('[data-strength]')?.addEventListener('input', (event) => {
      const v = event.target.value;
      const score = [v.length >= 14, /[A-Z]/.test(v), /[a-z]/.test(v), /\d/.test(v), /[^A-Za-z0-9]/.test(v), !/(.)\1{2,}/.test(v)].filter(Boolean).length;
      document.querySelector('[data-strength-result]').textContent = score >= 5 ? 'Fortaleza orientativa alta.' : score >= 3 ? 'Fortaleza orientativa media.' : 'Fortaleza orientativa baja.';
    });
    document.querySelector('[data-read-text]')?.addEventListener('input', (event) => {
      const words = event.target.value.trim().split(/\s+/).filter(Boolean).length;
      document.querySelector('[data-read-result]').textContent = `${Math.max(1, Math.ceil(words / 220))} min de lectura aproximada.`;
    });
    document.querySelector('[data-url-check]')?.addEventListener('input', (event) => {
      const value = event.target.value.trim();
      let message = 'Pega una URL para revisar señales básicas.';
      try {
        const url = new URL(value);
        const host = url.hostname.replace(/^www\./, '');
        const risky = ['bit.ly', 'tinyurl.com', 't.co', 'is.gd'].includes(host) || host.split('.').length > 3 || !url.protocol.startsWith('https');
        message = risky ? `Revisión prudente: ${host}. Evita iniciar sesión o pagar sin confirmar por canal oficial.` : `Señales básicas correctas: ${host}. Revisa igualmente contexto y destinatario.`;
      } catch {}
      document.querySelector('[data-url-result]').textContent = message;
    });
    const scoreChecks = (selector, output, labels) => {
      document.querySelector(selector)?.addEventListener('change', () => {
        const checked = document.querySelectorAll(`${selector} input:checked`).length;
        document.querySelector(output).textContent = checked >= 3 ? labels.high : checked >= 1 ? labels.medium : labels.low;
      });
    };
    scoreChecks('[data-cloud-audit]', '[data-cloud-result]', { low: 'Riesgo bajo orientativo: revisa destinatarios igualmente.', medium: 'Riesgo medio: limita enlace, permiso o usuarios externos.', high: 'Riesgo alto: conviene retirar enlace y compartir con personas concretas.' });
    scoreChecks('[data-extension-audit]', '[data-extension-result]', { low: 'Riesgo bajo orientativo: mantén solo extensiones necesarias.', medium: 'Riesgo medio: revisa si el permiso encaja con la función.', high: 'Riesgo alto: considera desinstalar o limitar acceso a sitios concretos.' });
  </script>
</DigiLayout>
