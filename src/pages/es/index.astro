---
import DigiLayout from '~/layouts/DigiLayout.astro';
import ArticleCard from '~/components/dc/ArticleCard.astro';
import { getArticles, site, topics, ui } from '~/data/digiclara';
import { withBase } from '~/utils/paths';

const lang = 'es';
const t = ui[lang];
const articles = getArticles(lang);
const featured = articles[0];
const visualTopics = ['security', 'privacy', 'windows', 'software', 'business', 'wifi'];
const used = new Set([featured.slug]);
const pick = (list, count) => {
  const selected = list.filter((article) => !used.has(article.slug)).slice(0, count);
  selected.forEach((article) => used.add(article.slug));
  return selected;
};
const sections = [
  [t.latest, pick(articles.slice(1), 3)],
  [t.security, pick(articles.filter((a) => a.topic === 'security'), 3)],
  [t.privacy, pick(articles.filter((a) => a.topic === 'privacy' || a.topic === 'wifi'), 3)],
  [t.comparisons, pick(articles.filter((a) => a.topic === 'comparisons'), 3)],
];
---

<DigiLayout lang={lang} title="Inicio" description={site.descriptions[lang]}>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">DigiClara</p>
        <h1>{site.slogans[lang]}</h1>
        <p class="lead">Guías prácticas, análisis independientes y recursos para proteger tus dispositivos, mejorar tu privacidad y elegir herramientas digitales con confianza.</p>
        <div class="button-row">
          <a class="button primary" href={withBase('/es/empieza-aqui/')}>Empieza aquí</a>
          <a class="button" href={withBase('/es/comparativas/')}>Ver comparativas</a>
        </div>
      </div>
      <div class="editorial-window"><div class="window-card"><img src={withBase('/assets/digiclara-logo.svg')} alt="DigiClara" /></div></div>
    </div>
  </section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.featured}</p><h2>{featured.title}</h2><p>{featured.summary}</p></header>
    <ArticleCard article={featured} lang={lang} />
  </div></section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">Categorías</p><h2>Temas principales</h2></header>
    <div class="grid grid-3">{visualTopics.map((key) => <a class="card" href={withBase(`/es/${topics[key].es.slug}/`)}><h3>{topics[key].es.name}</h3><p>{topics[key].es.summary}</p></a>)}</div>
  </div></section>

  {sections.map(([title, list]) => (
    <section class="section"><div class="page-shell"><header class="section-header"><h2>{title}</h2></header><div class="grid grid-4">{list.map((article) => <ArticleCard article={article} lang={lang} />)}</div></div></section>
  ))}

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.methodology}</p><h2>Transparencia antes que promesas</h2><p>Diferenciamos guías educativas, comparativas documentales y pruebas prácticas. Cuando no probamos algo directamente, lo indicamos.</p></header>
    <div class="grid grid-3">
      <div class="notice sage"><h3>Guías educativas</h3><p>Explican conceptos y pasos sin afirmar resultados medidos.</p></div>
      <div class="notice mustard"><h3>Comparativas documentales</h3><p>Comparan criterios públicos y limitaciones verificables.</p></div>
      <div class="notice"><h3>Pruebas prácticas</h3><p>Solo se declaran cuando realmente se han realizado.</p></div>
    </div>
  </div></section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.freeTools}</p><h2>Utilidades que funcionan en tu navegador</h2><p>No envían contraseñas ni textos a servidores.</p></header>
    <div class="grid grid-3">
      <a class="card" href={withBase('/es/herramientas/')}><h3>Generador de contraseñas</h3><p>Crea claves y frases de contraseña de forma local.</p></a>
      <a class="card" href={withBase('/es/herramientas/')}><h3>Revisor de enlaces y QR</h3><p>Evalúa señales básicas antes de abrir enlaces o escanear códigos.</p></a>
      <a class="card" href={withBase('/es/herramientas/')}><h3>Auditor de permisos</h3><p>Revisa enlaces en la nube y permisos de extensiones del navegador.</p></a>
    </div>
  </div></section>
</DigiLayout>
