---
import DigiLayout from '~/layouts/DigiLayout.astro';
import ArticleCard from '~/components/dc/ArticleCard.astro';
import { getArticles, site, topics, ui } from '~/data/digiclara';
import { withBase } from '~/utils/paths';

const lang = 'es';
const t = ui[lang];
const articles = getArticles(lang);
const featured = articles[0];
---

<DigiLayout lang={lang} title="Inicio" description={site.descriptions[lang]}>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">DigiClara</p>
        <h1>{site.slogans[lang]}</h1>
        <p class="lead">Guias practicas, analisis independientes y recursos para proteger tus dispositivos, mejorar tu privacidad y elegir herramientas digitales con confianza.</p>
        <div class="button-row">
          <a class="button primary" href={withBase('/es/guias/')}>Explorar guias</a>
          <a class="button" href={withBase('/es/comparativas/')}>Ver comparativas</a>
        </div>
      </div>
      <div class="editorial-window"><div class="window-card"><img src={withBase('/assets/digiclara-logo.svg')} alt="DigiClara" /></div></div>
    </div>
  </section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.featured}</p><h2>{featured.title}</h2><p>{featured.summary}</p></header>
    <ArticleCard article={featured} lang={lang} />
  </div></section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">Categorias</p><h2>Temas principales</h2></header>
    <div class="grid grid-4">{Object.values(topics).slice(0, 8).map((topic) => <a class="card" href={withBase(`/es/${topic.es.slug}/`)}><h3>{topic.es.name}</h3><p>{topic.es.summary}</p></a>)}</div>
  </div></section>

  {[
    [t.latest, articles.slice(1, 5)],
    [t.privacy, articles.filter((a) => a.topic === 'privacy').slice(0, 4)],
    [t.security, articles.filter((a) => a.topic === 'security').slice(0, 4)],
    [t.windows, articles.filter((a) => a.topic === 'windows').slice(0, 4)],
    [t.comparisons, articles.filter((a) => a.topic === 'comparisons').slice(0, 4)],
  ].map(([title, list]) => (
    <section class="section"><div class="page-shell"><header class="section-header"><h2>{title}</h2></header><div class="grid grid-4">{list.map((article) => <ArticleCard article={article} lang={lang} />)}</div></div></section>
  ))}

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.methodology}</p><h2>Transparencia antes que promesas</h2><p>Diferenciamos guias educativas, comparativas documentales y pruebas practicas. Cuando no probamos algo directamente, lo indicamos.</p></header>
    <div class="grid grid-3">
      <div class="notice sage"><h3>Guias educativas</h3><p>Explican conceptos y pasos sin afirmar resultados medidos.</p></div>
      <div class="notice mustard"><h3>Comparativas documentales</h3><p>Comparan criterios publicos y limitaciones verificables.</p></div>
      <div class="notice"><h3>Pruebas practicas</h3><p>Solo se declaran cuando realmente se han realizado.</p></div>
    </div>
  </div></section>

  <section class="section"><div class="page-shell"><div class="card"><h2>{t.subscribe}</h2><p>{t.subscribeText}</p></div></div></section>
</DigiLayout>
