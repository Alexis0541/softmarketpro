---
import Layout from '~/layouts/PageLayout.astro';
import { getLangFromUrl, localizePath, ui } from '~/utils/i18n';

const lang = getLangFromUrl(Astro.url);
const t = ui[lang];
const copy = {
  es: {
    metaTitle: 'Resumen de compra',
    metaDescription: 'Resumen del carrito y datos del cliente para recibir licencias digitales por email.',
    tag: 'Checkout',
    title: 'Resumen de compra',
    intro: 'Revisa tus productos y completa tus datos. Las licencias se enviaran al email indicado tras confirmar el pago.',
    customer: 'Datos del cliente',
    firstName: 'Nombre',
    lastName: 'Apellidos',
    email: 'Email donde recibiras las licencias',
    phone: 'Telefono',
    country: 'Pais',
    address: 'Direccion de facturacion',
    city: 'Ciudad',
    postcode: 'Codigo postal',
    payment: 'Metodo de pago',
    countries: ['Espana', 'Portugal', 'Francia', 'Alemania', 'Italia', 'Otro pais de la Union Europea'],
    payments: ['Tarjeta bancaria', 'PayPal', 'Transferencia bancaria'],
    accept: 'Acepto los terminos de compra, politica de privacidad y envio digital de licencias por email.',
    confirm: 'Confirmar pedido',
    note: 'Esta pantalla deja listo el flujo. Falta conectar la pasarela de pago real y el envio automatico de claves.',
    cart: 'Tu carrito',
    subtotal: 'Subtotal',
    vat: 'IVA incluido',
    included: 'Incluido',
    total: 'Total',
    empty: 'No hay productos en el carrito. Vuelve a la tienda para anadir licencias.',
    quantity: 'Cantidad',
    emptyAlert: 'Tu carrito esta vacio.',
    success: 'Pedido recibido. En produccion aqui se procesaria el pago y se enviarian las licencias por email.',
  },
  en: {
    metaTitle: 'Order summary',
    metaDescription: 'Cart summary and customer details to receive digital licenses by email.',
    tag: 'Checkout',
    title: 'Order summary',
    intro: 'Review your products and complete your details. Licenses will be sent to the email address provided after payment confirmation.',
    customer: 'Customer details',
    firstName: 'First name',
    lastName: 'Last name',
    email: 'Email where you will receive the licenses',
    phone: 'Phone',
    country: 'Country',
    address: 'Billing address',
    city: 'City',
    postcode: 'Postcode',
    payment: 'Payment method',
    countries: ['Spain', 'Portugal', 'France', 'Germany', 'Italy', 'Other European Union country'],
    payments: ['Bank card', 'PayPal', 'Bank transfer'],
    accept: 'I accept the purchase terms, privacy policy and digital delivery of licenses by email.',
    confirm: 'Confirm order',
    note: 'This screen prepares the flow. A real payment gateway and automatic key delivery still need to be connected.',
    cart: 'Your cart',
    subtotal: 'Subtotal',
    vat: 'VAT included',
    included: 'Included',
    total: 'Total',
    empty: 'There are no products in the cart. Return to the store to add licenses.',
    quantity: 'Quantity',
    emptyAlert: 'Your cart is empty.',
    success: 'Order received. In production, payment would be processed here and licenses would be sent by email.',
  },
}[lang];

const metadata = {
  title: copy.metaTitle,
  description: copy.metaDescription,
};
---

<Layout metadata={metadata} lang={lang}>
  <section class="not-prose bg-slate-50 px-4 py-12 dark:bg-slate-900 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <div class="mb-8">
        <p class="font-bold uppercase tracking-wide text-primary">{copy.tag}</p>
        <h1 class="mt-2 text-4xl font-black tracking-tight dark:text-white">{copy.title}</h1>
        <p class="mt-3 max-w-3xl text-slate-600 dark:text-slate-300">{copy.intro}</p>
      </div>

      <div class="grid gap-8 lg:grid-cols-[1fr_420px]">
        <form class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950" data-checkout-form>
          <h2 class="text-2xl font-black dark:text-white">{copy.customer}</h2>
          <div class="mt-6 grid gap-5 sm:grid-cols-2">
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.firstName}</span><input required name="nombre" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.lastName}</span><input required name="apellidos" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block sm:col-span-2"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.email}</span><input required type="email" name="email" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.phone}</span><input required type="tel" name="telefono" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.country}</span><select required name="pais" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900">{copy.countries.map((country) => <option>{country}</option>)}</select></label>
            <label class="block sm:col-span-2"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.address}</span><input required name="direccion" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.city}</span><input required name="ciudad" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.postcode}</span><input required name="codigo_postal" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block sm:col-span-2"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.payment}</span><select required name="pago" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900">{copy.payments.map((payment) => <option>{payment}</option>)}</select></label>
          </div>

          <label class="mt-5 flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
            <input required type="checkbox" class="mt-1" />
            {copy.accept}
          </label>

          <button class="mt-6 w-full rounded-md bg-green-600 px-5 py-4 text-base font-black text-white hover:bg-green-700" type="submit">
            {copy.confirm}
          </button>
          <p class="mt-3 text-sm text-slate-500">{copy.note}</p>
        </form>

        <aside class="h-fit rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950">
          <h2 class="text-2xl font-black dark:text-white">{copy.cart}</h2>
          <div class="mt-5" data-checkout-items></div>
          <div class="mt-5 border-t border-slate-200 pt-5 dark:border-slate-800">
            <div class="flex justify-between text-sm text-slate-600 dark:text-slate-300"><span>{copy.subtotal}</span><span data-checkout-subtotal>0,00 €</span></div>
            <div class="mt-2 flex justify-between text-sm text-slate-600 dark:text-slate-300"><span>{copy.vat}</span><span>{copy.included}</span></div>
            <div class="mt-4 flex justify-between text-xl font-black dark:text-white"><span>{copy.total}</span><span data-checkout-total>0,00 €</span></div>
          </div>
        </aside>
      </div>
    </div>
  </section>

  <script define:vars={{ locale: t.locale, emptyText: copy.empty, quantityText: copy.quantity, emptyAlert: copy.emptyAlert, successText: copy.success }}>
    // @ts-nocheck
    const cartKey = 'softmarket-cart';
    const euro = new Intl.NumberFormat(locale, { style: 'currency', currency: 'EUR' });
    const itemsNode = document.querySelector('[data-checkout-items]');

    const readCart = () => {
      try {
        return JSON.parse(localStorage.getItem(cartKey) || '[]');
      } catch {
        return [];
      }
    };

    const renderCheckout = () => {
      const cart = readCart();
      const total = cart.reduce((sum, item) => sum + item.price * item.quantity, 0);

      document.querySelector('[data-checkout-subtotal]').textContent = euro.format(total);
      document.querySelector('[data-checkout-total]').textContent = euro.format(total);

      if (cart.length === 0) {
        itemsNode.innerHTML = `<p class="rounded-md bg-slate-100 p-4 text-sm text-slate-600 dark:bg-slate-900 dark:text-slate-300">${emptyText}</p>`;
        return;
      }

      itemsNode.innerHTML = cart.map((item) => `
        <div class="mb-4 flex gap-3 rounded-md border border-slate-200 p-3 dark:border-slate-800">
          <img src="${item.image}" alt="${item.name}" class="h-16 w-16 rounded bg-slate-100 object-contain p-1" />
          <div class="min-w-0 flex-1">
            <h3 class="text-sm font-bold dark:text-white">${item.name}</h3>
            <p class="text-sm text-slate-500">${quantityText}: ${item.quantity}</p>
            <p class="text-sm font-black text-primary">${euro.format(item.price * item.quantity)}</p>
          </div>
        </div>
      `).join('');
    };

    document.querySelector('[data-checkout-form]').addEventListener('submit', (event) => {
      event.preventDefault();
      if (readCart().length === 0) {
        alert(emptyAlert);
        return;
      }
      alert(successText);
    });

    renderCheckout();
  </script>
</Layout>
