---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import ContactUs from '~/components/widgets/Contact.astro';
import Features2 from '~/components/widgets/Features2.astro';
import { getLangFromUrl } from '~/utils/i18n';

const lang = getLangFromUrl(Astro.url);
const copy = {
  es: {
    metaTitle: 'Contacto',
    tag: 'Contacto',
    title: 'Hablemos de tu licencia',
    formTitle: 'Escribenos hoy',
    formSubtitle: 'Atendemos dudas sobre compras, activaciones, facturas, pedidos por volumen y soporte tecnico.',
    name: 'Nombre',
    email: 'Email',
    message: 'Mensaje',
    disclaimer: 'Al enviar este formulario aceptas que usemos tus datos para responder a tu consulta.',
    button: 'Enviar mensaje',
    description: 'Normalmente respondemos dentro de 24 horas laborables.',
    helpTitle: 'Estamos aqui para ayudar',
    items: [
      ['Soporte general', 'Consultas sobre pedidos, cuenta de cliente, carrito, estado de compra o funcionamiento de la tienda.'],
      ['Ventas y volumen', 'Preguntas sobre varias licencias, presupuestos para empresas, tecnicos, autonomos o compras recurrentes.'],
      ['Soporte tecnico', 'Ayuda con instalacion, activacion, compatibilidad, descargas o incidencias con licencias digitales.'],
      ['Telefono', '+34 900 000 000', 'tabler:headset'],
      ['Email', 'soporte@softmarketpro.es', 'tabler:mail'],
      ['Ubicacion', 'Espana', 'tabler:map-pin'],
    ],
  },
  en: {
    metaTitle: 'Contact',
    tag: 'Contact',
    title: 'Let us talk about your license',
    formTitle: 'Send us a message today',
    formSubtitle: 'We help with purchase questions, activations, invoices, volume orders and technical support.',
    name: 'Name',
    email: 'Email',
    message: 'Message',
    disclaimer: 'By submitting this form, you agree that we may use your details to answer your request.',
    button: 'Send message',
    description: 'We usually respond within 24 business hours.',
    helpTitle: 'We are here to help',
    items: [
      ['General support', 'Questions about orders, customer account, cart, purchase status or store operation.'],
      ['Sales and volume', 'Questions about multiple licenses, quotes for businesses, technicians, freelancers or recurring purchases.'],
      ['Technical support', 'Help with installation, activation, compatibility, downloads or issues with digital licenses.'],
      ['Phone', '+34 900 000 000', 'tabler:headset'],
      ['Email', 'support@softmarketpro.es', 'tabler:mail'],
      ['Location', 'Spain', 'tabler:map-pin'],
    ],
  },
}[lang];

const metadata = {
  title: copy.metaTitle,
};
---

<Layout metadata={metadata} lang={lang}>
  <HeroText tagline={copy.tag} title={copy.title} />

  <ContactUs
    id="form"
    title={copy.formTitle}
    subtitle={copy.formSubtitle}
    inputs={[
      { type: 'text', name: 'name', label: copy.name },
      { type: 'email', name: 'email', label: copy.email },
    ]}
    textarea={{ label: copy.message }}
    disclaimer={{ label: copy.disclaimer }}
    button={copy.button}
    description={copy.description}
  />

  <Features2
    title={copy.helpTitle}
    items={copy.items.map(([title, description, icon]) => ({ title, description, icon }))}
  />
</Layout>
