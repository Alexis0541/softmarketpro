---
import Layout from '~/layouts/PageLayout.astro';
import { getLangFromUrl } from '~/utils/i18n';

const lang = getLangFromUrl(Astro.url);
const copy = {
  es: {
    metaTitle: 'Mi cuenta',
    metaDescription: 'Registro e inicio de sesion para clientes de la tienda de licencias.',
    tag: 'Clientes',
    title: 'Mi cuenta',
    intro: 'Accede a tus pedidos, licencias, facturas y datos de cliente.',
    loginTitle: 'Iniciar sesion',
    loginSubtitle: 'Para clientes registrados.',
    email: 'Correo electronico',
    password: 'Contrasena',
    remember: 'Recordarme',
    forgot: 'Olvide mi contrasena',
    loginButton: 'Iniciar sesion',
    registerTitle: 'Registrarse',
    registerSubtitle: 'Crea una cuenta para guardar pedidos y facturas.',
    firstName: 'Nombre',
    lastName: 'Apellidos',
    phone: 'Telefono',
    country: 'Pais',
    confirmPassword: 'Confirmar contrasena',
    address: 'Direccion de facturacion',
    countries: ['Espana', 'Portugal', 'Francia', 'Alemania', 'Italia', 'Otro pais de la Union Europea'],
    accept: 'Acepto la politica de privacidad y los terminos de uso.',
    registerButton: 'Crear cuenta',
    loginAlert: 'Inicio de sesion preparado. Falta conectar autenticacion real.',
    registerAlert: 'Registro preparado. Falta conectar base de datos y autenticacion real.',
  },
  en: {
    metaTitle: 'My account',
    metaDescription: 'Registration and sign-in for customers of the license store.',
    tag: 'Customers',
    title: 'My account',
    intro: 'Access your orders, licenses, invoices and customer details.',
    loginTitle: 'Sign in',
    loginSubtitle: 'For registered customers.',
    email: 'Email address',
    password: 'Password',
    remember: 'Remember me',
    forgot: 'Forgot my password',
    loginButton: 'Sign in',
    registerTitle: 'Register',
    registerSubtitle: 'Create an account to save orders and invoices.',
    firstName: 'First name',
    lastName: 'Last name',
    phone: 'Phone',
    country: 'Country',
    confirmPassword: 'Confirm password',
    address: 'Billing address',
    countries: ['Spain', 'Portugal', 'France', 'Germany', 'Italy', 'Other European Union country'],
    accept: 'I accept the privacy policy and terms of use.',
    registerButton: 'Create account',
    loginAlert: 'Sign-in flow prepared. Real authentication still needs to be connected.',
    registerAlert: 'Registration flow prepared. Database and real authentication still need to be connected.',
  },
}[lang];

const metadata = {
  title: copy.metaTitle,
  description: copy.metaDescription,
};
---

<Layout metadata={metadata} lang={lang}>
  <section class="not-prose bg-slate-50 px-4 py-12 dark:bg-slate-900 sm:px-6">
    <div class="mx-auto max-w-6xl">
      <div class="mb-8 text-center">
        <p class="font-bold uppercase tracking-wide text-primary">{copy.tag}</p>
        <h1 class="mt-2 text-4xl font-black tracking-tight dark:text-white">{copy.title}</h1>
        <p class="mt-3 text-slate-600 dark:text-slate-300">{copy.intro}</p>
      </div>

      <div class="grid gap-8 lg:grid-cols-2">
        <form class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950" data-login-form>
          <h2 class="text-2xl font-black dark:text-white">{copy.loginTitle}</h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{copy.loginSubtitle}</p>

          <label class="mt-6 block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.email}</span><input required type="email" name="email" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
          <label class="mt-5 block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.password}</span><input required type="password" name="password" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>

          <div class="mt-5 flex items-center justify-between gap-4 text-sm">
            <label class="flex items-center gap-2 text-slate-600 dark:text-slate-300"><input type="checkbox" />{copy.remember}</label>
            <a class="font-bold text-primary" href="#">{copy.forgot}</a>
          </div>

          <button class="mt-6 w-full rounded-md bg-primary px-5 py-4 font-black text-white hover:bg-primary/90" type="submit">
            {copy.loginButton}
          </button>
        </form>

        <form class="rounded-md border border-slate-200 bg-white p-6 shadow-sm dark:border-slate-800 dark:bg-slate-950" data-register-form>
          <h2 class="text-2xl font-black dark:text-white">{copy.registerTitle}</h2>
          <p class="mt-2 text-sm text-slate-600 dark:text-slate-300">{copy.registerSubtitle}</p>

          <div class="mt-6 grid gap-5 sm:grid-cols-2">
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.firstName}</span><input required name="nombre" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.lastName}</span><input required name="apellidos" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block sm:col-span-2"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.email}</span><input required type="email" name="email" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.phone}</span><input required type="tel" name="telefono" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.country}</span><select required name="pais" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900">{copy.countries.map((country) => <option>{country}</option>)}</select></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.password}</span><input required type="password" name="password" minlength="8" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.confirmPassword}</span><input required type="password" name="password_confirm" minlength="8" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
            <label class="block sm:col-span-2"><span class="text-sm font-bold text-slate-700 dark:text-slate-200">{copy.address}</span><input name="direccion" class="mt-2 w-full rounded-md border border-slate-300 px-4 py-3 outline-none focus:border-primary focus:ring-2 focus:ring-primary/20 dark:border-slate-700 dark:bg-slate-900" /></label>
          </div>

          <label class="mt-5 flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300"><input required type="checkbox" class="mt-1" />{copy.accept}</label>

          <button class="mt-6 w-full rounded-md bg-green-600 px-5 py-4 font-black text-white hover:bg-green-700" type="submit">
            {copy.registerButton}
          </button>
        </form>
      </div>
    </div>
  </section>

  <script define:vars={{ loginAlert: copy.loginAlert, registerAlert: copy.registerAlert }}>
    document.querySelector('[data-login-form]').addEventListener('submit', (event) => {
      event.preventDefault();
      alert(loginAlert);
    });

    document.querySelector('[data-register-form]').addEventListener('submit', (event) => {
      event.preventDefault();
      alert(registerAlert);
    });
  </script>
</Layout>
