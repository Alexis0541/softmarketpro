---
import DigiLayout from '~/layouts/DigiLayout.astro';
import { site } from '~/data/digiclara';
---
<DigiLayout lang="en" title="Contact" description="DigiClara editorial contact.">
  <section class="section"><div class="page-shell article-body">
    <p class="eyebrow">Contact</p>
    <h1>Editorial contact</h1>
    <p>DigiClara is editorially managed by {site.ownerName}. The site is run from Spain and handles corrections, suggestions, technical issues and editorial proposals by email.</p>
    <div class="notice sage">
      <h2>Contact details</h2>
      <p><strong>Owner:</strong> {site.ownerName}</p>
      <p><strong>Role:</strong> DigiClara editorial lead</p>
      <p><strong>Country:</strong> Spain</p>
      <p><strong>Email:</strong> <a href={`mailto:${site.email}`}>{site.email}</a></p>
    </div>
    <a class="button primary" href={`mailto:${site.email}?subject=Inquiry%20from%20DigiClara`}>Send an email</a>
  </div></section>
</DigiLayout>
