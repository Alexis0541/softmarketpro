---
import DigiLayout from '~/layouts/DigiLayout.astro';
import { ui } from '~/data/digiclara';
const t = ui.en;
---
<DigiLayout lang="en" title="Contact" description="DigiClara editorial contact form.">
  <section class="section"><div class="page-shell article-body">
    <h1>Editorial contact</h1><p>{t.contactNote}</p>
    <form data-contact-form>
      <label>Name<input required name="name" /></label>
      <label>Email<input required type="email" name="email" /></label>
      <label>Subject<input required name="subject" /></label>
      <label>Inquiry type<select><option>Content correction</option><option>Suggestion</option><option>Technical issue</option><option>Editorial inquiry</option><option>Collaboration</option><option>Other</option></select></label>
      <label>Message<textarea required rows="6"></textarea></label>
      <label><input required type="checkbox" /> I agree that these details may be used to answer my request when the form is configured.</label>
      <button class="button primary" type="submit">Validate form</button>
    </form>
  </div></section>
  <script>document.querySelector('[data-contact-form]')?.addEventListener('submit', (e) => { e.preventDefault(); alert('Form validated. No information is sent because no backend is configured.'); });</script>
</DigiLayout>
