---
import DigiLayout from '~/layouts/DigiLayout.astro';
import ArticleCard from '~/components/dc/ArticleCard.astro';
import { getArticles, site, topics, ui } from '~/data/digiclara';
import { withBase } from '~/utils/paths';

const lang = 'en';
const t = ui[lang];
const articles = getArticles(lang);
const featured = articles[0];
const visualTopics = ['security', 'privacy', 'windows', 'software', 'business', 'wifi'];
---

<DigiLayout lang={lang} title="Home" description={site.descriptions[lang]}>
  <section class="hero">
    <div class="hero-grid">
      <div>
        <p class="eyebrow">DigiClara</p>
        <h1>{site.slogans[lang]}</h1>
        <p class="lead">Practical guides, independent analysis, and resources to protect your devices, improve your privacy, and choose digital tools with confidence.</p>
        <div class="button-row">
          <a class="button primary" href={withBase('/en/guides/')}>Explore guides</a>
          <a class="button" href={withBase('/en/comparisons/')}>View comparisons</a>
        </div>
      </div>
      <div class="editorial-window"><div class="window-card"><img src={withBase('/assets/digiclara-logo.svg')} alt="DigiClara" /></div></div>
    </div>
  </section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.featured}</p><h2>{featured.title}</h2><p>{featured.summary}</p></header>
    <ArticleCard article={featured} lang={lang} />
  </div></section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">Categories</p><h2>Main topics</h2></header>
    <div class="grid grid-3">{visualTopics.map((key) => <a class="card" href={withBase(`/en/${topics[key].en.slug}/`)}><h3>{topics[key].en.name}</h3><p>{topics[key].en.summary}</p></a>)}</div>
  </div></section>

  {[
    [t.latest, articles.slice(1, 5)],
    [t.privacy, articles.filter((a) => a.topic === 'privacy').slice(0, 4)],
    [t.security, articles.filter((a) => a.topic === 'security').slice(0, 4)],
    [t.windows, articles.filter((a) => a.topic === 'windows').slice(0, 4)],
    [t.comparisons, articles.filter((a) => a.topic === 'comparisons').slice(0, 4)],
  ].map(([title, list]) => (
    <section class="section"><div class="page-shell"><header class="section-header"><h2>{title}</h2></header><div class="grid grid-4">{list.map((article) => <ArticleCard article={article} lang={lang} />)}</div></div></section>
  ))}

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.methodology}</p><h2>Transparency before promises</h2><p>We separate educational guides, documentary comparisons and practical tests. When we did not test something directly, we say so.</p></header>
    <div class="grid grid-3">
      <div class="notice sage"><h3>Educational guides</h3><p>They explain concepts and steps without claiming measured results.</p></div>
      <div class="notice mustard"><h3>Documentary comparisons</h3><p>They compare public criteria and verifiable limitations.</p></div>
      <div class="notice"><h3>Practical tests</h3><p>They are declared only when they have actually been performed.</p></div>
    </div>
  </div></section>

  <section class="section"><div class="page-shell">
    <header class="section-header"><p class="eyebrow">{t.freeTools}</p><h2>Utilities that run in your browser</h2><p>They do not send passwords or text to servers.</p></header>
    <div class="grid grid-3">
      <a class="card" href={withBase('/en/tools/')}><h3>Password generator</h3><p>Create passwords and passphrases locally.</p></a>
      <a class="card" href={withBase('/en/tools/')}><h3>Phishing checklist</h3><p>Review warning signs before opening links or attachments.</p></a>
      <a class="card" href={withBase('/en/tools/')}><h3>Reading calculator</h3><p>Estimate reading time without sending text outside the browser.</p></a>
    </div>
  </div></section>
</DigiLayout>
