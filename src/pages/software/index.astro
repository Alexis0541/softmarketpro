---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductGrid from '~/components/widgets/ProductGrid.astro';
import { getCategories, getProducts } from '~/data/software';
import { getLangFromUrl, localizePath } from '~/utils/i18n';

const lang = getLangFromUrl(Astro.url);
const categories = getCategories(lang);
const products = getProducts(lang);

const copy = {
  es: {
    metaTitle: 'Tienda de licencias de software',
    metaDescription: 'Compra licencias digitales para Windows, Office, Adobe, Corel, servidores y packs con IVA incluido.',
    tag: 'Catalogo',
    title: 'Compra licencias por categoria',
    subtitle: 'Encuentra licencias digitales para Windows, Office, Adobe, Corel, servidores y packs.',
    enter: 'Entrar',
    productsTag: 'Productos',
    productsTitle: 'Todos los productos',
    productsSubtitle: 'Anade licencias al carrito y prepara el pedido desde la propia tienda.',
    ctaTitle: 'Catalogo en crecimiento',
    ctaSubtitle: 'El catalogo ya esta preparado para carrito, descuentos, cupones y pasarela de pago.',
    deals: 'Ver ofertas',
    home: 'Volver al inicio',
  },
  en: {
    metaTitle: 'Software license store',
    metaDescription: 'Buy digital licenses for Windows, Office, Adobe, Corel, servers and bundles with VAT included.',
    tag: 'Catalog',
    title: 'Buy licenses by category',
    subtitle: 'Find digital licenses for Windows, Office, Adobe, Corel, servers and bundles.',
    enter: 'Enter',
    productsTag: 'Products',
    productsTitle: 'All products',
    productsSubtitle: 'Add licenses to the cart and prepare the order directly inside the store.',
    ctaTitle: 'Growing catalog',
    ctaSubtitle: 'The catalog is ready for cart, discounts, coupons and payment gateway features.',
    deals: 'View deals',
    home: 'Back to home',
  },
}[lang];

const metadata = {
  title: copy.metaTitle,
  description: copy.metaDescription,
};
---

<Layout metadata={metadata} lang={lang}>
  <Features
    tagline={copy.tag}
    title={copy.title}
    subtitle={copy.subtitle}
    columns={3}
    items={categories.map((category) => ({
      title: category.name,
      description: category.description,
      icon: category.icon,
      callToAction: { text: copy.enter, href: localizePath(`/software/${category.slug}`, lang) },
    }))}
  />

  <ProductGrid tagline={copy.productsTag} title={copy.productsTitle} subtitle={copy.productsSubtitle} products={products} lang={lang} />

  <CallToAction
    actions={[
      { variant: 'primary', text: copy.deals, href: '#productos', icon: 'tabler:star' },
      { text: copy.home, href: localizePath('/', lang), icon: 'tabler:home' },
    ]}
  >
    <Fragment slot="title">{copy.ctaTitle}</Fragment>
    <Fragment slot="subtitle">{copy.ctaSubtitle}</Fragment>
  </CallToAction>
</Layout>
