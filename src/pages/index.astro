---
import Layout from '~/layouts/PageLayout.astro';
import Features from '~/components/widgets/Features.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import ProductGrid from '~/components/widgets/ProductGrid.astro';
import { formatPrice, getCategories, getProducts } from '~/data/software';
import { getLangFromUrl, localizePath } from '~/utils/i18n';
import { getPermalink } from '~/utils/permalinks';

const lang = getLangFromUrl(Astro.url);
const categories = getCategories(lang);
const products = getProducts(lang);

const copy = {
  es: {
    metaTitle: 'SoftMarket Pro | Licencias originales de software con IVA',
    metaDescription:
      'Tienda online de licencias digitales para Windows, Office, Adobe, Corel, servidores y packs. Entrega por email, factura con IVA y soporte en espanol.',
    badge: 'Envio inmediato + IVA incluido',
    h1: 'Licencias originales de Windows, Office, Adobe y mas para empresas y particulares',
    intro:
      'Compra tu clave digital, recibela por email y activa tu software con soporte real en espanol. Sin enlaces a terceros: todo el pedido se gestiona dentro de esta tienda.',
    seeDeals: 'Ver ofertas',
    volume: 'Presupuesto por volumen',
    trustTag: 'Compra con confianza',
    trustTitle: 'Licencias digitales con soporte y factura',
    features: [
      ['Factura con IVA', 'Pensado para empresas, autonomos y particulares que necesitan justificante de compra.', 'tabler:file-invoice'],
      ['Entrega por email', 'Recibe la clave y las instrucciones de activacion tras completar el pedido.', 'tabler:mail-check'],
      ['Soporte en espanol', 'Ayuda para instalar, activar y resolver incidencias durante el proceso.', 'tabler:headset'],
      ['Pago seguro', 'Preparado para conectar Redsys, Stripe, PayPal o transferencia bancaria.', 'tabler:shield-check'],
    ],
    categoriesTag: 'Categorias',
    categoriesTitle: 'Encuentra la licencia que necesitas',
    categoriesSubtitle: 'Organizamos la tienda por familias de software para que el usuario llegue rapido al producto correcto.',
    seeCategory: 'Ver',
    dealsTag: 'Ofertas destacadas',
    dealsTitle: 'Licencias mas vendidas',
    dealsSubtitle: 'Precios en euros con IVA incluido, basados en productos y precios visibles en tiendas de software de referencia.',
    processTag: 'Proceso simple',
    processTitle: 'Activa tu software en 3 pasos',
    steps: [
      ['1', 'Comprar', 'Elige la licencia, anadela al carrito y completa el pedido.'],
      ['2', 'Recibir', 'Te enviamos la clave digital, factura e instrucciones por email.'],
      ['3', 'Activar', 'Instala el software y activa la licencia con soporte si lo necesitas.'],
    ],
    faqTag: 'Preguntas frecuentes',
    faqTitle: 'Antes de comprar',
    faqSubtitle: 'Resuelve las dudas mas habituales sobre entrega, activacion, factura y soporte.',
    faqs: [
      ['Cuanto tarda en llegar la licencia?', 'La tienda esta planteada para entrega digital por email. Al conectar el pago real, el envio puede automatizarse tras la confirmacion del pedido.'],
      ['Los precios incluyen IVA?', 'Si. Los productos se muestran en euros con IVA incluido, siguiendo el enfoque de tienda para Espana.'],
      ['Puedo comprar varias licencias?', 'Si. El carrito permite sumar unidades. Despues se puede anadir una funcion de descuentos por volumen para empresas y tecnicos.'],
      ['Ya se puede cobrar online?', 'Ahora el carrito prepara el pedido. Falta conectar una pasarela como Redsys, Stripe, PayPal o transferencia para procesar pagos reales.'],
    ],
    ctaTitle: 'Tienda preparada para vender licencias',
    ctaSubtitle: 'El siguiente paso es conectar pago, emails automaticos y gestion de inventario de claves.',
    store: 'Ir a la tienda',
    askHelp: 'Solicitar ayuda',
  },
  en: {
    metaTitle: 'SoftMarket Pro | Original software licenses with VAT',
    metaDescription:
      'Online store for digital licenses for Windows, Office, Adobe, Corel, servers and bundles. Email delivery, VAT invoice and English support.',
    badge: 'Instant delivery + VAT included',
    h1: 'Original Windows, Office, Adobe and software licenses for businesses and home users',
    intro:
      'Buy your digital key, receive it by email and activate your software with real support in English. No third-party redirects: the whole order stays inside this store.',
    seeDeals: 'View deals',
    volume: 'Volume quote',
    trustTag: 'Buy with confidence',
    trustTitle: 'Digital licenses with support and invoice',
    features: [
      ['VAT invoice', 'Built for businesses, freelancers and home users who need a purchase receipt.', 'tabler:file-invoice'],
      ['Email delivery', 'Receive the key and activation instructions after completing the order.', 'tabler:mail-check'],
      ['English support', 'Help with installation, activation and issues during the process.', 'tabler:headset'],
      ['Secure payment', 'Ready to connect Redsys, Stripe, PayPal or bank transfer.', 'tabler:shield-check'],
    ],
    categoriesTag: 'Categories',
    categoriesTitle: 'Find the license you need',
    categoriesSubtitle: 'The store is organized by software families so customers reach the right product quickly.',
    seeCategory: 'View',
    dealsTag: 'Featured deals',
    dealsTitle: 'Best-selling licenses',
    dealsSubtitle: 'Prices in euros with VAT included, based on products and prices visible in reference software stores.',
    processTag: 'Simple process',
    processTitle: 'Activate your software in 3 steps',
    steps: [
      ['1', 'Buy', 'Choose the license, add it to the cart and complete the order.'],
      ['2', 'Receive', 'We send the digital key, invoice and instructions by email.'],
      ['3', 'Activate', 'Install the software and activate the license with support if needed.'],
    ],
    faqTag: 'Frequently asked questions',
    faqTitle: 'Before buying',
    faqSubtitle: 'Clear up the most common questions about delivery, activation, invoice and support.',
    faqs: [
      ['How long does the license take to arrive?', 'The store is designed for digital email delivery. After connecting real payments, delivery can be automated after order confirmation.'],
      ['Do prices include VAT?', 'Yes. Products are shown in euros with VAT included, following a Spain-focused store model.'],
      ['Can I buy several licenses?', 'Yes. The cart lets you add units. A volume discount feature can be added later for businesses and technicians.'],
      ['Can the store charge online already?', 'The cart currently prepares the order. A gateway such as Redsys, Stripe, PayPal or bank transfer still needs to be connected for real payments.'],
    ],
    ctaTitle: 'Store ready to sell licenses',
    ctaSubtitle: 'The next step is connecting payment, automatic emails and license-key inventory management.',
    store: 'Go to store',
    askHelp: 'Request help',
  },
}[lang];

const metadata = {
  title: copy.metaTitle,
  ignoreTitleTemplate: true,
  description: copy.metaDescription,
};
---

<Layout metadata={metadata} lang={lang}>
  <section class="not-prose bg-slate-950 text-white">
    <div class="mx-auto grid max-w-7xl gap-10 px-4 py-16 sm:px-6 lg:grid-cols-[1.05fr_0.95fr] lg:items-center lg:py-20">
      <div>
        <p class="mb-4 inline-flex rounded bg-green-500 px-3 py-1 text-sm font-black text-slate-950">{copy.badge}</p>
        <h1 class="text-4xl font-black leading-tight tracking-tight sm:text-5xl lg:text-6xl">{copy.h1}</h1>
        <p class="mt-5 max-w-2xl text-lg text-slate-300">{copy.intro}</p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a class="rounded-md bg-primary px-6 py-4 text-center font-black text-white shadow hover:bg-primary/90" href="#productos">
            {copy.seeDeals}
          </a>
          <a class="rounded-md border border-white/30 px-6 py-4 text-center font-black text-white hover:bg-white/10" href={getPermalink(localizePath('/contact', lang))}>
            {copy.volume}
          </a>
        </div>
      </div>

      <div class="rounded-md bg-white p-5 shadow-2xl">
        <div class="grid grid-cols-2 gap-4">
          {products.slice(0, 4).map((product) => (
            <div class="rounded border border-slate-200 p-3 text-slate-950">
              <img class="mx-auto h-24 object-contain" src={product.image} alt={product.name} />
              <p class="mt-3 text-sm font-bold leading-snug">{product.name}</p>
              <p class="mt-1 text-lg font-black text-primary">{formatPrice(product.price, lang)}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <Features
    tagline={copy.trustTag}
    title={copy.trustTitle}
    columns={4}
    items={copy.features.map(([title, description, icon]) => ({ title, description, icon }))}
  />

  <Features
    id="categorias"
    tagline={copy.categoriesTag}
    title={copy.categoriesTitle}
    subtitle={copy.categoriesSubtitle}
    columns={3}
    items={categories.map((category) => ({
      title: category.name,
      description: category.description,
      icon: category.icon,
      callToAction: { text: `${copy.seeCategory} ${category.name}`, href: getPermalink(localizePath(`/software/${category.slug}`, lang)) },
    }))}
  />

  <ProductGrid id="productos" tagline={copy.dealsTag} title={copy.dealsTitle} subtitle={copy.dealsSubtitle} products={products} limit={8} lang={lang} />

  <section class="not-prose bg-slate-50 px-4 py-16 dark:bg-slate-900 sm:px-6">
    <div class="mx-auto max-w-7xl">
      <div class="mb-10 text-center">
        <p class="font-bold uppercase tracking-wide text-primary">{copy.processTag}</p>
        <h2 class="mt-2 text-4xl font-black tracking-tight dark:text-white">{copy.processTitle}</h2>
      </div>
      <div class="grid gap-6 md:grid-cols-3">
        {copy.steps.map(([number, title, text]) => (
          <div class="rounded-md border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-950">
            <span class="flex h-12 w-12 items-center justify-center rounded-full bg-primary text-xl font-black text-white">{number}</span>
            <h3 class="mt-5 text-2xl font-black dark:text-white">{title}</h3>
            <p class="mt-3 text-slate-600 dark:text-slate-300">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FAQs
    id="faq"
    tagline={copy.faqTag}
    title={copy.faqTitle}
    subtitle={copy.faqSubtitle}
    items={copy.faqs.map(([title, description]) => ({ title, description }))}
  />

  <CallToAction
    actions={[
      { variant: 'primary', text: copy.store, href: getPermalink(localizePath('/software', lang)), icon: 'tabler:shopping-bag' },
      { text: copy.askHelp, href: getPermalink(localizePath('/contact', lang)), icon: 'tabler:message' },
    ]}
  >
    <Fragment slot="title">{copy.ctaTitle}</Fragment>
    <Fragment slot="subtitle">{copy.ctaSubtitle}</Fragment>
  </CallToAction>
</Layout>
